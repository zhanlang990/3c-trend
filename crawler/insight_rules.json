{
  "brand_keywords": {
    "艾谱": "艾谱",
    "AIPU": "艾谱",
    "aipu": "艾谱",
    "虎牌": "虎牌",
    "TIGER": "虎牌",
    "tiger": "虎牌",
    "永发": "永发",
    "得力": "得力",
    "deli": "得力",
    "DELI": "得力",
    "迪堡": "迪堡",
    "Diebold": "迪堡",
    "全能": "全能",
    "QNN": "全能",
    "驰球": "驰球",
    "金虎": "金虎",
    "杰宝": "杰宝大王",
    "盾牌": "盾牌Guarda",
    "Guarda": "盾牌Guarda"
  },
  "rules": [
    {
      "match_any": ["销量第一", "销冠", "TOP1", "连续三年", "霸榜", "登顶"],
      "template": "{brand}销量势能强劲，建议优先锁定主推坑位并加大同价位段SKU备货深度。"
    },
    {
      "match_any": ["新品", "发布会", "上市", "推出", "首发"],
      "template": "{brand}新品上市，建议跟进首发坑位与达人种草节奏，抢占新品红利期。"
    },
    {
      "match_any": ["指纹", "智能", "WiFi", "wifi", "物联网", "人脸识别", "远程"],
      "template": "智能化保险柜需求持续升温，建议增加指纹/智能锁SKU占比，匹配中高端家庭客群。"
    },
    {
      "match_any": ["防火", "防弹", "防潮", "军工", "装甲"],
      "template": "高防护规格成卖点突破口，可孵化差异化标品页与场景化视频素材。"
    },
    {
      "match_any": ["豪宅", "别墅", "高端", "豪雅", "金标", "尊"],
      "template": "高端保险柜需求扩张，建议提升5000+价位段SKU深度并联动家装类目运营。"
    },
    {
      "match_any": ["双十一", "618", "大促", "年中", "双11", "双12"],
      "template": "大促节点临近，建议提前锁定品牌坑位、配置满减券组合并备好低价引流款。"
    },
    {
      "match_any": ["国标", "3C", "认证", "标准", "GB"],
      "template": "认证合规成消费决策核心因素，详情页应强化国标/3C资质曝光，淘汰非标低质SKU。"
    },
    {
      "match_any": ["跨界", "家具", "床头柜", "嵌入", "隐形", "入墙"],
      "template": "家具化保险柜带动场景融合，可联合家装类目设置组合套装与样板间种草。"
    },
    {
      "match_any": ["融资", "投资", "并购", "上市公司", "IPO", "战略合作"],
      "template": "{brand}资本动作释放扩张信号，建议密切关注其后续渠道与营销投入节奏。"
    },
    {
      "match_any": ["出口", "海外", "全球", "国际", "一带一路"],
      "template": "出海动向值得关注，跨境业务可借势品牌外溢效应同步推广国内中高端线。"
    }
  ],
  "fallback": "持续关注{brand}动态，评估其对相关价格带与流量节奏的边际影响。"
}